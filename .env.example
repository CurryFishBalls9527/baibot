# Copy this file to `.env` and fill in only the providers/features you use.
# Never commit your real `.env`.

# Required for most CLI / agent workflows if you use OpenAI models.
OPENAI_API_KEY=

# Optional alternative LLM providers.
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Required only if you want Alpaca paper/live trading or account status.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Optional market/news provider used by some research flows.
ALPHA_VANTAGE_API_KEY=

# Optional trading-system behavior.
# Use `broad` for dynamic broad-market scanning, or `growth` for the fixed growth watchlist.
TRADING_UNIVERSE=broad
OVERLAY_ENABLED=0

# Optional phone notifications via ntfy.
NTFY_ENABLED=0
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

# Optional social-monitor topic if enabled.
SOCIAL_MONITOR_ENABLED=0
SOCIAL_MONITOR_USERNAMES=markminervini
SOCIAL_CHECK_INTERVAL_MINUTES=5
SOCIAL_NTFY_ENABLED=0
SOCIAL_NTFY_TOPIC=
